# Node.js Server Port
PORT=5000

# Telegram Client Configuration (from https://my.telegram.org)
API_ID=your_api_id_here
API_HASH=your_api_hash_here
PHONE=+998901234567

# Groq AI Configuration
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/infast-lms

# Auto Reply Configuration
AUTO_REPLY_CONTACTS=false
AUTO_REPLY_UNKNOWN=true

# Response Delay (in seconds)
MIN_DELAY=5
MAX_DELAY=15

# Python Microservice Configuration
TELEGRAM_CLIENT_PORT=5001
TELEGRAM_CLIENT_HOST=localhost
BACKEND_URL=http://localhost:5000
