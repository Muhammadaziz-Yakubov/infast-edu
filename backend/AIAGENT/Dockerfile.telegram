FROM python:3.11-slim

# Set working directory
WORKDIR /app

# Install system dependencies if required (Telethon and Cryptography needs build utilities in some cases, but slim is usually fine)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Copy and install python dependencies
COPY src/telegram/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Copy microservice source code
COPY src/telegram/ ./src/telegram/
# Copy root env file for configurations
COPY .env ./

# Expose microservice HTTP port
EXPOSE 5001

# Start the Telethon client
CMD ["python", "src/telegram/client.py"]
